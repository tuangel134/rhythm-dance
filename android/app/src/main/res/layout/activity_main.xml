<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#05060F">

    <!-- WebView del juego (oculto hasta conectar) -->
    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Pantalla de conexion -->
    <ScrollView
        android:id="@+id/connectPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◤ ◣ ◆ ◢ ◥"
                android:textColor="#29E7FF"
                android:textSize="30sp"
                android:letterSpacing="0.2"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="34sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/connect_help"
                android:textColor="#8B8FB0"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="22dp" />

            <EditText
                android:id="@+id/serverUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/server_hint"
                android:textColorHint="#5B6080"
                android:textColor="#FFFFFF"
                android:inputType="textUri"
                android:imeOptions="actionGo"
                android:background="#11162B"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/connectBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/connect"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#FF2D7E"
                android:padding="14dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/connect_note"
                android:textColor="#5B6080"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="20dp" />
        </LinearLayout>
    </ScrollView>
</FrameLayout>
