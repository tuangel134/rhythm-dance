<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Necesita internet para conectarse al servidor del juego (tu PC o el
         enlace publico). usesCleartextTraffic permite http:// en LAN. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Lectura de la carpeta de musica elegida por el usuario. -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.RhythmDance">

        <!-- Pantalla de inicio: elegir jugar nativo o conectar a PC -->
        <activity
            android:name=".HomeActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:launchMode="singleTask">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Selector de cancion + dificultad (juego nativo) -->
        <activity
            android:name=".SongPickerActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode" />

        <!-- Juego nativo en el telefono -->
        <activity
            android:name=".GameActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:screenOrientation="sensorPortrait" />

        <!-- Juego web COMPLETO embebido (offline, sin PC) -->
        <activity
            android:name=".GameWebViewActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:screenOrientation="portrait"
            android:launchMode="singleTask" />

        <!-- Cliente WebView a una PC (modo anterior) -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|uiMode"
            android:screenOrientation="sensorLandscape"
            android:launchMode="singleTask" />
    </application>
</manifest>
